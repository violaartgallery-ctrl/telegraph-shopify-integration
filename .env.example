PORT=3000
LOG_LEVEL=info
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
SYNC_OPEN_SHIPMENTS_INTERVAL_MS=3600000
SYNC_OPEN_SHIPMENTS_BATCH_SIZE=10
# Maximum time (ms) for one sync-open-shipments run before stopping early to avoid Netlify timeout.
# Default 20000 leaves ~6 s buffer from Netlify's 26 s function limit. Reduce if sync is slow.
SYNC_TIME_BUDGET_MS=20000
SHIPMENT_CODE_PREFIX=VI
SHIPMENT_CODE_START=200
ORDER_REFERENCE_PREFIX=Viola
ODOO_SYNC_ENABLED=false
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_PAYMENT_JOURNAL_ID=
# Odoo account ID for the expense line of Telegraph return-charge vendor bills.
# Required when Odoo sync is enabled and returns occur.
# Find it: Odoo → Accounting → Configuration → Chart of Accounts → locate your return/shipping expense account
ODOO_RETURN_CHARGE_ACCOUNT_ID=

# ── Security ────────────────────────────────────────────────────────────────
# Token required to access admin routes (/orders/*, /api/*).
# Supply via header: x-admin-secret: <token>
# or query param: ?adminToken=<token>
# Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=
# Required by every /ops endpoint in production. Send as x-ops-secret.
OPS_SECRET=

# Meta Conversions API: real courier-delivered-and-collected orders only.
# Safe defaults keep the sender disabled and in Test Events mode.
META_DELIVERED_ENABLED=false
META_DELIVERED_MODE=test
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_API_VERSION=v25.0
META_TEST_EVENT_CODE=
# ISO-8601. Both Shopify order creation and actual delivery must be on/after it.
META_DELIVERED_CUTOVER_AT=
META_EVENT_SOURCE_URL=https://violaleather.com
META_DELIVERED_BATCH_SIZE=25
META_DELIVERED_LEASE_MS=120000
META_REQUEST_TIMEOUT_MS=10000
META_DELIVERED_MAX_ATTEMPTS=12

SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_STOREFRONT_URL=https://violaleather.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2025-10

ACCURATE_GRAPHQL_ENDPOINT=https://system.telegraphex.com:8443/graphql
ACCURATE_USERNAME=
ACCURATE_PASSWORD=
# Shared secret for incoming Accurate/Telegraph webhook calls.
# Set the same value in Telegraph's webhook configuration panel.
# Supply via header: x-accurate-webhook-secret: <secret>
# or query param: ?webhookSecret=<secret>
ACCURATE_WEBHOOK_SECRET=
ACCURATE_DEFAULT_BRANCH_ID=
ACCURATE_DEFAULT_SERVICE_ID=
ACCURATE_DEFAULT_CUSTOMER_ID=
ACCURATE_DEFAULT_SHIPMENT_TYPE=
# Set this to the Accurate code you want to use for created shipments
# e.g. CASH / PAID / COLC depending on your workflow
ACCURATE_DEFAULT_PAYMENT_TYPE=

# Optional but strongly recommended for recipient zone fallback
ACCURATE_DEFAULT_RECIPIENT_ZONE_ID=
ACCURATE_DEFAULT_RECIPIENT_SUBZONE_ID=

# Optional sender defaults
ACCURATE_SENDER_NAME=
ACCURATE_SENDER_PHONE=
ACCURATE_SENDER_MOBILE=
ACCURATE_SENDER_ADDRESS=
ACCURATE_SENDER_POSTAL_CODE=
ACCURATE_SENDER_ZONE_ID=
ACCURATE_SENDER_SUBZONE_ID=

# Optional enum/config defaults
ACCURATE_DEFAULT_PRICE_TYPE=INCLD
ACCURATE_DEFAULT_OPENABLE_CODE=
ACCURATE_DEFAULT_PIECES_COUNT=1
ACCURATE_DEFAULT_WEIGHT=

# Optional SKU -> Accurate product id map as JSON, e.g. {"SKU123":101,"SKU456":102}
ACCURATE_PRODUCT_ID_MAP_JSON=
ACCURATE_DEFAULT_PRODUCT_TYPE_CODE=

# Optional Shopify metafield target for shipment status
SHOPIFY_STATUS_METAFIELD_NAMESPACE=accurate
SHOPIFY_STATUS_METAFIELD_KEY=shipment_status
SHOPIFY_COLLECTION_METAFIELD_KEY=collection_status
SHOPIFY_COLLECTED_AMOUNT_METAFIELD_KEY=collected_amount
SHOPIFY_RETURNED_VALUE_METAFIELD_KEY=returned_value
SHOPIFY_TRACKING_URL_METAFIELD_KEY=tracking_url
SHOPIFY_SYNC_SUMMARY_METAFIELD_KEY=sync_summary
# Telegram chat ids that receive the exact production batch after /run finishes.
# Comma-separated. Defaults in code to Ahmed Galal and Ayman when omitted.
PRODUCTION_RECIPIENT_CHAT_IDS=6776051391,8615245657
PRODUCTION_ALERT_CHAT_IDS=6776051391,8615245657
PRODUCTION_BASE_URL=https://viola-telegraph-integration.vercel.app
PRODUCTION_RESUME_SECRET=
PRODUCTION_JOB_DEADLINE_MS=235000
PRODUCTION_MAX_AUTO_RETRIES=8
OPS_SECRET=
AYMAN_AGENT_URL=https://viola-production-agent.vercel.app
AYMAN_AGENT_SECRET=
