<header class="site-header" style="{% if section.settings.bg_color != blank %}background-color: {{ section.settings.bg_color }};{% endif %}">
  {% assign has_announcements = false %}
  {% for block in section.blocks %}
    {% if block.type == 'announcement' and block.settings.text != blank %}
      {% assign has_announcements = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if section.settings.show_announcement and has_announcements %}
    <div class="announcement-bar" style="background: {{ section.settings.announcement_bg | default: '#c9a96e' }}; color: {{ section.settings.announcement_color | default: '#fff' }};" {{ section.shopify_attributes }}>
      <div class="announcement-marquee">
        <div class="announcement-marquee-track">
          {% for block in section.blocks %}
            {% if block.type == 'announcement' and block.settings.text != blank %}
              <span class="announcement-marquee-item" {{ block.shopify_attributes }}>
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" style="color: {{ section.settings.announcement_color | default: '#fff' }};">{{ block.settings.text }}</a>
                {% else %}
                  {{ block.settings.text }}
                {% endif %}
              </span>
            {% endif %}
          {% endfor %}
          {% for block in section.blocks %}
            {% if block.type == 'announcement' and block.settings.text != blank %}
              <span class="announcement-marquee-item" aria-hidden="true">
                {% if block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" style="color: {{ section.settings.announcement_color | default: '#fff' }};" tabindex="-1">{{ block.settings.text }}</a>
                {% else %}
                  {{ block.settings.text }}
                {% endif %}
              </span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  <div class="container">
    <div class="header-inner">
      <div class="header-mobile-left">
        <button class="menu-toggle" aria-label="Menu" data-open="mobile-menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
      <a href="/" class="header-logo">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" loading="lazy" style="height: {{ section.settings.logo_height }}px; width: auto;">
        {% elsif shop.brand and shop.brand.logo %}
          <img src="{{ shop.brand.logo | image_url: width: 200 }}" alt="{{ shop.name }}" loading="lazy" style="height: {{ section.settings.logo_height }}px; width: auto;">
        {% else %}
          <span class="header-logo-text" style="{% if section.settings.logo_text_color != blank %}color: {{ section.settings.logo_text_color }};{% endif %}">{{ section.settings.logo_text | default: shop.name }}</span>
        {% endif %}
      </a>
      <nav>
        <ul class="header-nav">
          {% if section.settings.show_home_link %}
            <li><a href="/">{{ section.settings.home_label | default: 'Home' }}</a></li>
          {% endif %}
          {% for link in linklists[section.settings.menu].links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
          {% if section.settings.show_all_products_link %}
            <li><a href="/collections/all">{{ section.settings.all_products_label | default: 'All Products' }}</a></li>
          {% endif %}
        </ul>
      </nav>
      <div class="header-actions">
        {% if section.settings.show_search %}
          <a href="/search" class="cart-link header-desktop-only" aria-label="Search">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </a>
        {% endif %}
        {% if section.settings.show_cart %}
          {% assign header_promo_cart_count = 0 %}
          {% for item in cart.items %}
            {% unless item.variant_id == 54003265929508 %}
              {% assign header_promo_cart_count = header_promo_cart_count | plus: item.quantity %}
            {% endunless %}
          {% endfor %}
          <button class="cart-link cart-toggle" aria-label="Cart" data-open="cart-drawer">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span class="cart-count">{{ header_promo_cart_count }}</span>
          </button>
        {% endif %}
      </div>
    </div>
  </div>
</header>

<div class="drawer-overlay" data-close="mobile-menu"></div>
<div class="drawer drawer-left" id="mobile-menu">
  <div class="drawer-header">
    <span class="drawer-title">Menu</span>
    <button class="drawer-close" data-close="mobile-menu" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <nav class="drawer-nav">
    {% if section.settings.show_home_link %}
      <a href="/" class="drawer-link">{{ section.settings.home_label | default: 'Home' }}</a>
    {% endif %}
    {% for link in linklists[section.settings.menu].links %}
      <a href="{{ link.url }}" class="drawer-link">{{ link.title }}</a>
    {% endfor %}
    {% if section.settings.show_all_products_link %}
      <a href="/collections/all" class="drawer-link">{{ section.settings.all_products_label | default: 'All Products' }}</a>
    {% endif %}
  </nav>
</div>

<div class="drawer-overlay" data-close="cart-drawer"></div>
<div class="drawer drawer-right" id="cart-drawer">
  <div class="drawer-header">
    {% assign promo_cart_count = 0 %}
    {% assign promo_cart_total = 0 %}
    {% for item in cart.items %}
      {% unless item.variant_id == 54003265929508 %}
        {% assign promo_cart_count = promo_cart_count | plus: item.quantity %}
        {% assign promo_cart_total = promo_cart_total | plus: item.final_line_price %}
      {% endunless %}
    {% endfor %}
    <span class="drawer-title">Cart ({{ promo_cart_count }})</span>
    <button class="drawer-close" data-close="cart-drawer" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="drawer-body" id="cart-drawer-body">
    {% if cart.item_count > 0 %}
      {% assign drawer_threshold = section.settings.free_shipping_threshold | default: 1500 %}
      {% assign drawer_threshold_cents = drawer_threshold | times: 100 %}
      {% assign drawer_remaining = drawer_threshold_cents | minus: promo_cart_total %}
      {% assign drawer_progress = promo_cart_total | times: 100 | divided_by: drawer_threshold_cents %}
      {% if drawer_progress > 100 %}{% assign drawer_progress = 100 %}{% endif %}
      <div class="drawer-shipping-bar">
        <div class="drawer-shipping-bar__text">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#111" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          {% if promo_cart_total >= drawer_threshold_cents %}
            <span>Free shipping earned!</span>
          {% else %}
            <span><strong>{{ drawer_remaining | money }}</strong> away from free shipping</span>
          {% endif %}
        </div>
        <div class="drawer-shipping-bar__track">
          <div class="drawer-shipping-bar__fill" style="width: {{ drawer_progress }}%;"></div>
        </div>
      </div>
      {% for item in cart.items %}
        <div class="cart-drawer-item">
          <div class="cart-drawer-img">
            {% if item.image %}
              <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}">
            {% endif %}
          </div>
          <div class="cart-drawer-info">
            <a href="{{ item.url }}" class="cart-drawer-name">{{ item.product.title }}</a>
            {% unless item.variant.title == 'Default Title' %}
              <div class="cart-drawer-variant">{{ item.variant.title }}</div>
            {% endunless %}
            {% if item.properties != blank %}
              <div class="cart-line-properties">
                {% for property in item.properties %}
                  {% assign property_first_char = property.first | slice: 0 %}
                  {% if property.last != blank and property_first_char != '_' %}
                    <div class="cart-line-property">
                      <strong>{{ property.first }}:</strong>
                      {% if property.last contains '/uploads/' %}
                        <a href="{{ property.last }}" target="_blank" rel="noopener">عرض الملف</a>
                      {% else %}
                        <span>{{ property.last }}</span>
                      {% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
            <div class="cart-drawer-controls">
              <div class="cart-qty-wrap">
                <button type="button" class="cart-qty-btn cart-qty-minus" data-key="{{ item.key }}" data-qty="{{ item.quantity | minus: 1 }}" aria-label="Decrease">−</button>
                <span class="cart-qty-num">{{ item.quantity }}</span>
                <button type="button" class="cart-qty-btn cart-qty-plus" data-key="{{ item.key }}" data-qty="{{ item.quantity | plus: 1 }}" aria-label="Increase">+</button>
              </div>
              <button type="button" class="cart-remove-btn" data-key="{{ item.key }}" aria-label="Remove">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
              </button>
            </div>
            <div class="cart-drawer-price">{{ item.line_price | money }}</div>
          </div>
        </div>
      {% endfor %}
    {% else %}
      <div class="cart-drawer-empty">
        <p>Your cart is empty</p>
      </div>
    {% endif %}
  </div>
  {% if cart.item_count > 0 %}
    <div class="drawer-footer">
      <div class="cart-drawer-total">
        <span>Total</span>
        <span>{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="cart-drawer-checkout">Checkout</a>
      <a href="/cart" class="cart-drawer-viewcart">View Cart</a>
    </div>
  {% endif %}
</div>

<style>
  .announcement-bar {
    padding: 0; font-size: 0.85rem;
    font-weight: 600; font-family: var(--font-heading);
    overflow: hidden; position: relative;
  }
  .announcement-marquee {
    overflow: hidden;
    width: 100%;
    padding: 0.5rem 0;
  }
  .announcement-marquee-track {
    display: inline-flex;
    white-space: nowrap;
    animation: marquee-scroll {{ section.settings.marquee_speed | default: 30 }}s linear infinite;
  }
  .announcement-marquee:hover .announcement-marquee-track {
    animation-play-state: paused;
  }
  .announcement-marquee-item {
    display: inline-block;
    padding: 0 3rem;
  }
  .announcement-marquee-item a {
    text-decoration: none;
  }
  .announcement-marquee-item a:hover {
    text-decoration: underline;
  }
  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Cart Drawer Shipping Bar */
  .drawer-shipping-bar {
    padding: 0.65rem 1rem;
    margin: 0 -1.25rem 0.75rem;
    background: #f5f5f5;
    border-bottom: 1px solid #e0e0e0;
    position: sticky;
    top: 0;
    z-index: 1;
  }
  .drawer-shipping-bar__text {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: #111;
    margin-bottom: 0.35rem;
  }
  .drawer-shipping-bar__track {
    width: 100%;
    height: 6px;
    background: #e0e0e0;
    border-radius: 3px;
    overflow: hidden;
  }
  .drawer-shipping-bar__fill {
    height: 100%;
    background: #111;
    border-radius: 3px;
    transition: width 0.4s ease;
  }

  .drawer-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.5);
    z-index: 9998; opacity: 0; visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .drawer-overlay.open { opacity: 1; visibility: visible; }
  .drawer {
    position: fixed; top: 0; bottom: 0;
    width: 300px; max-width: 85vw;
    background: #ffffff; z-index: 9999;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex; flex-direction: column;
    box-shadow: 0 0 30px rgba(0,0,0,0.15);
  }
  .drawer-left { left: 0; transform: translateX(-100%); }
  .drawer-right { right: 0; transform: translateX(100%); }
  .drawer.open { transform: translateX(0); }
  .drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .drawer-title {
    font-family: var(--font-heading); font-weight: 700;
    font-size: 1.1rem; color: var(--color-primary);
  }
  .drawer-close {
    background: none; border: none; padding: 0.25rem;
    color: var(--color-text); cursor: pointer;
    transition: color 0.2s ease;
  }
  .drawer-close:hover { color: var(--color-accent); }
  .drawer-nav {
    padding: 1rem 0; flex: 1; overflow-y: auto;
  }
  .drawer-link {
    display: block; padding: 0.85rem 1.25rem;
    font-size: 1rem; font-weight: 500; color: var(--color-text);
    transition: all 0.2s ease; font-family: var(--font-heading);
    border-bottom: 1px solid var(--color-surface);
  }
  .drawer-link:hover { background: var(--color-surface); color: var(--color-accent); padding-left: 1.5rem; }
  .drawer-body { flex: 1; overflow-y: auto; padding: 1rem 1.25rem; }
  .cart-drawer-item {
    display: flex; gap: 0.75rem; padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: opacity 0.3s ease;
  }
  .cart-drawer-img {
    width: 64px; height: 64px; border-radius: 8px;
    overflow: hidden; flex-shrink: 0; background: var(--color-surface);
  }
  .cart-drawer-img img { width: 100%; height: 100%; object-fit: cover; }
  .cart-drawer-info { flex: 1; min-width: 0; }
  .cart-drawer-name {
    font-weight: 600; font-size: 0.88rem; font-family: var(--font-heading);
    color: var(--color-primary); display: block;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .cart-drawer-variant { font-size: 0.78rem; color: var(--color-text-light); }
  .cart-drawer-qty { font-size: 0.78rem; color: var(--color-text-light); }
  .cart-drawer-price { font-weight: 700; color: var(--color-accent); font-size: 0.9rem; margin-top: 0.2rem; }
  .cart-drawer-empty {
    text-align: center; padding: 3rem 0; color: var(--color-text-light);
  }
  .drawer-footer {
    padding: 1rem 1.25rem; border-top: 1px solid var(--color-border);
    flex-shrink: 0; background: #ffffff;
  }
  .cart-drawer-total {
    display: flex; justify-content: space-between;
    font-weight: 700; font-size: 1.05rem; margin-bottom: 0.75rem;
    font-family: var(--font-heading);
  }
  .cart-drawer-checkout {
    display: block; width: 100%; padding: 0.85rem;
    background: var(--color-primary); color: #fff;
    border-radius: var(--radius-md); text-align: center;
    font-weight: 700; font-family: var(--font-heading);
    font-size: 0.95rem; transition: background 0.3s ease;
    margin-bottom: 0.5rem;
  }
  .cart-drawer-checkout:hover { background: var(--color-accent); }
  .cart-drawer-viewcart {
    display: block; text-align: center; font-size: 0.85rem;
    color: var(--color-text-light); font-weight: 500;
  }
  .cart-drawer-viewcart:hover { color: var(--color-accent); }
  .cart-drawer-controls {
    display: flex; align-items: center; justify-content: space-between; margin-top: 0.35rem;
  }
  .cart-qty-wrap {
    display: flex; align-items: center; border: 1px solid var(--color-border);
    border-radius: 8px; overflow: hidden;
  }
  .cart-qty-btn {
    width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    background: none; border: none; font-size: 1rem; font-weight: 600;
    color: var(--color-text); cursor: pointer; transition: background 0.2s ease;
    font-family: var(--font-heading);
  }
  .cart-qty-btn:hover { background: var(--color-surface); }
  .cart-qty-btn:disabled { opacity: 0.4; cursor: default; }
  .cart-qty-num {
    width: 32px; text-align: center; font-size: 0.85rem;
    font-weight: 600; font-family: var(--font-heading);
  }
  .cart-remove-btn {
    background: none; border: none; padding: 0.25rem; color: #999;
    cursor: pointer; transition: color 0.2s ease; display: flex; align-items: center;
  }
  .cart-remove-btn:hover { color: #e53e3e; }
</style>

<script>
(function() {
  var PHOTO_PRINTING_FEE_VARIANT_ID = '54003265929508';

  function isPhotoPrintingFeeItem(item) {
    if (!item) return false;
    if (String(item.variant_id || item.id || '') === PHOTO_PRINTING_FEE_VARIANT_ID) return true;
    var props = item.properties || {};
    return props._viola_fee_type === 'photo_printing' || props._exclude_from_promos === 'true';
  }

  function getPromoCartItemCount(cart) {
    return (cart.items || []).reduce(function(count, item) {
      return isPhotoPrintingFeeItem(item) ? count : count + (item.quantity || 0);
    }, 0);
  }

  document.querySelectorAll('[data-open]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var id = this.getAttribute('data-open');
      var drawer = document.getElementById(id);
      var overlays = document.querySelectorAll('.drawer-overlay[data-close="' + id + '"]');
      if (drawer) { drawer.classList.add('open'); }
      overlays.forEach(function(o) { o.classList.add('open'); });
      document.body.style.overflow = 'hidden';
    });
  });
  function closeDrawer(id) {
    var drawer = document.getElementById(id);
    var overlays = document.querySelectorAll('.drawer-overlay[data-close="' + id + '"]');
    if (drawer) drawer.classList.remove('open');
    overlays.forEach(function(o) { o.classList.remove('open'); });
    document.body.style.overflow = '';
  }
  document.querySelectorAll('[data-close]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      closeDrawer(this.getAttribute('data-close'));
    });
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Logo height",
      "default": 44
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (if no image)",
      "default": "VIOLA"
    },
    {
      "type": "color",
      "id": "logo_text_color",
      "label": "Logo text color"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "checkbox",
      "id": "show_home_link",
      "label": "Show Home link",
      "default": true
    },
    {
      "type": "text",
      "id": "home_label",
      "label": "Home link label",
      "default": "Home"
    },
    {
      "type": "checkbox",
      "id": "show_all_products_link",
      "label": "Show All Products link",
      "default": true
    },
    {
      "type": "text",
      "id": "all_products_label",
      "label": "All Products label",
      "default": "All Products"
    },
    {
      "type": "header",
      "content": "Actions"
    },
    {
      "type": "checkbox",
      "id": "show_cart",
      "label": "Show cart icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": false
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "color",
      "id": "announcement_bg",
      "label": "Announcement background",
      "default": "#c9a96e"
    },
    {
      "type": "color",
      "id": "announcement_color",
      "label": "Announcement text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Marquee scroll speed",
      "default": 30,
      "info": "Lower = faster scrolling"
    },
    {
      "type": "header",
      "content": "Free Shipping Bar (Cart Drawer)"
    },
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "min": 100,
      "max": 2000,
      "step": 50,
      "unit": "EGP",
      "label": "Free shipping threshold",
      "default": 1500
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Header background color"
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Announcement text",
          "default": "Buy 2 Get Free Shipping"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
