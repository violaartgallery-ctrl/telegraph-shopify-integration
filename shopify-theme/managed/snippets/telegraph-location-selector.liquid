<style>
  .telegraph-location {
    border: 1px solid var(--color-border, #e0e0e0);
    border-radius: 10px;
    margin: 0 0 0.85rem;
    padding: 0.85rem;
    background: #ffffff;
    text-align: start;
  }
  .telegraph-location__title {
    margin: 0 0 0.3rem;
    color: var(--color-primary, #111111);
    font-family: var(--font-heading, inherit);
    font-size: 0.92rem;
    font-weight: 800;
  }
  .telegraph-location__hint {
    margin: 0 0 0.75rem;
    color: var(--color-text-light, #777777);
    font-size: 0.78rem;
    line-height: 1.4;
  }
  .telegraph-location__grid {
    display: grid;
    gap: 0.65rem;
  }
  .telegraph-location__field {
    display: grid;
    gap: 0.35rem;
  }
  .telegraph-location__label {
    color: var(--color-text, #111111);
    font-size: 0.74rem;
    font-weight: 700;
  }
  .telegraph-location__select {
    width: 100%;
    min-height: 42px;
    border: 1px solid var(--color-border, #d0d0d0);
    border-radius: 8px;
    background: #ffffff;
    color: var(--color-text, #111111);
    font: inherit;
    font-size: 0.86rem;
    padding: 0.6rem 0.7rem;
  }
  .telegraph-location__select:disabled {
    background: #f5f5f5;
    color: #888888;
  }
  .telegraph-location__status {
    min-height: 18px;
    color: #b42318;
    font-size: 0.76rem;
    font-weight: 700;
  }
  .telegraph-location__status.is-ok {
    color: #166534;
  }
  .telegraph-checkout-disabled {
    opacity: 0.55;
  }
</style>

<script>
(function() {
  var locationsCache = null;
  var locationsPromise = null;
  var locationsAssetUrl = {{ 'telegraph-locations.json' | asset_url | json }};
  var locationsFallbackUrl = 'https://viola-telegraph-integration.vercel.app/api/accurate/locations';
  var localLocationsTimeoutMs = 3000;
  var fallbackLocationsTimeoutMs = 6000;
  var cartTimeoutMs = 3000;
  var cartUpdateTimeoutMs = 8000;
  var mountRunId = 0;
  var saveRevision = 0;
  var saveQueue = Promise.resolve();
  var savePending = false;
  var saveFailed = false;
  var attributeKeys = {
    governorateId: 'Telegraph Governorate ID',
    governorate: 'Telegraph Governorate',
    areaId: 'Telegraph Area ID',
    area: 'Telegraph Area'
  };

  function sameOriginAssetUrl(assetUrl) {
    try {
      var parsed = new URL(assetUrl, window.location.origin);
      return parsed.pathname + parsed.search;
    } catch (error) {
      // asset_url is generated by Shopify, but keep a safe relative fallback
      // for older browsers that do not expose the URL constructor.
      return String(assetUrl || '').replace(/^https?:\/\/[^/]+/i, '').replace(/^\/\/[^/]+/i, '');
    }
  }

  var localLocationsUrl = sameOriginAssetUrl(locationsAssetUrl);

  function fetchJsonWithTimeout(url, timeoutMs, label, requestOptions) {
    var controller = typeof window.AbortController === 'function' ? new window.AbortController() : null;
    var timeoutId;
    var request = Promise.resolve().then(function() {
      var options = {};
      Object.keys(requestOptions || {}).forEach(function(key) { options[key] = requestOptions[key]; });
      if (!options.credentials) options.credentials = 'same-origin';
      if (!options.headers) options.headers = { 'Accept': 'application/json' };
      if (controller) options.signal = controller.signal;
      return fetch(url, options);
    }).then(function(response) {
      if (!response.ok) throw new Error(label + ' returned HTTP ' + response.status);
      return response.json();
    });
    var timeout = new Promise(function(resolve, reject) {
      timeoutId = window.setTimeout(function() {
        if (controller) controller.abort();
        reject(new Error(label + ' timed out after ' + timeoutMs + 'ms'));
      }, timeoutMs);
    });

    return Promise.race([request, timeout]).then(function(payload) {
      window.clearTimeout(timeoutId);
      return payload;
    }, function(error) {
      window.clearTimeout(timeoutId);
      throw error;
    });
  }

  function locationsFromPayload(payload, label) {
    if (!payload || !Array.isArray(payload.locations) || !payload.locations.length) {
      throw new Error(label + ' returned no locations');
    }
    var validLocations = payload.locations.filter(function(zone) {
      return zone && Array.isArray(zone.subzones) && zone.subzones.length > 0;
    });
    if (!validLocations.length) throw new Error(label + ' returned no valid delivery zones');
    return validLocations;
  }

  function loadLocations(url, timeoutMs, label) {
    return fetchJsonWithTimeout(url, timeoutMs, label).then(function(payload) {
      return locationsFromPayload(payload, label);
    });
  }

  function fetchLocations() {
    if (locationsCache) return Promise.resolve(locationsCache);
    if (locationsPromise) return locationsPromise;
    // Prefer the versioned theme asset on the storefront origin. Vercel is a
    // bounded fallback only, so an unavailable external service cannot leave
    // checkout initialization pending forever.
    locationsPromise = loadLocations(localLocationsUrl, localLocationsTimeoutMs, 'Local locations asset')
      .catch(function(localError) {
        return loadLocations(locationsFallbackUrl, fallbackLocationsTimeoutMs, 'Vercel locations fallback');
      })
      .then(function(locations) {
        locationsCache = locations;
        return locationsCache;
      })
      .catch(function(error) {
        // Do not permanently cache a rejection: a later cart open can retry.
        locationsPromise = null;
        throw error;
      });
    return locationsPromise;
  }

  function fetchCart() {
    return fetchJsonWithTimeout('/cart.js', cartTimeoutMs, 'Cart');
  }

  function updateCartAttributes(attributes) {
    return fetchJsonWithTimeout('/cart/update.js', cartUpdateTimeoutMs, 'Cart update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ attributes: attributes })
    }).then(function(cart) {
      var saved = (cart && cart.attributes) || {};
      var matches = Object.keys(attributes).every(function(key) {
        return String(saved[key] || '') === String(attributes[key] || '');
      });
      if (!matches) throw new Error('Cart attributes did not match the latest delivery selection');
      return cart;
    });
  }

  function makeOption(value, label, selected) {
    var option = document.createElement('option');
    option.value = value;
    option.textContent = label;
    option.selected = selected;
    return option;
  }

  function currentSelection(cart) {
    var attrs = cart && cart.attributes ? cart.attributes : {};
    return {
      governorateId: attrs[attributeKeys.governorateId] || '',
      governorate: attrs[attributeKeys.governorate] || '',
      areaId: attrs[attributeKeys.areaId] || '',
      area: attrs[attributeKeys.area] || ''
    };
  }

  function hasSelection(selection) {
    return Boolean(selection.governorateId && selection.areaId);
  }

  function validatedSelection(cart, locations) {
    var raw = currentSelection(cart);
    var zone = locations.find(function(entry) {
      return String(entry.id) === String(raw.governorateId);
    });
    var area = zone ? zone.subzones.find(function(entry) {
      return String(entry.id) === String(raw.areaId);
    }) : null;
    return {
      governorateId: zone ? String(zone.id) : '',
      governorate: zone ? zone.name : '',
      areaId: area ? String(area.id) : '',
      area: area ? area.name : ''
    };
  }

  // Every path a buyer can take to checkout: standard links, the cart form's
  // checkout button, and any element we tag as a trigger.
  // theme-premium.js turns #buy-now-btn into add-to-cart + /cart. It is not a
  // checkout trigger and must always reach the product handler.
  var PRODUCT_BUY_NOW_SELECTOR = '#buy-now-btn';
  var CHECKOUT_TRIGGER_SELECTOR = 'a[href="/checkout"]:not(#buy-now-btn), a[href^="/checkout?"]:not(#buy-now-btn), button[name="checkout"], [data-telegraph-checkout-trigger]:not(#buy-now-btn)';
  // Accelerated/express buttons (Shop Pay, PayPal, Apple/Google Pay) jump
  // straight to checkout, bypassing the cart + this picker entirely.
  var EXPRESS_SELECTOR = '.shopify-payment-button, [data-shopify="payment-button"], .additional-checkout-buttons, .dynamic-checkout__content';
  var selectedGlobal = false;

  function setCheckoutState(root, selected) {
    selectedGlobal = selected;
    document.querySelectorAll(CHECKOUT_TRIGGER_SELECTOR).forEach(function(el) {
      el.classList.toggle('telegraph-checkout-disabled', !selected);
      el.setAttribute('aria-disabled', selected ? 'false' : 'true');
      if (!selected) el.setAttribute('data-telegraph-block-checkout', 'true');
      else el.removeAttribute('data-telegraph-block-checkout');
    });
    // Hide express checkout until a zone is chosen — otherwise the server-side
    // validation just rejects the order after the buyer already committed.
    document.querySelectorAll(EXPRESS_SELECTOR).forEach(function(el) {
      el.style.display = selected ? '' : 'none';
    });
    if (root) {
      var status = root.querySelector('[data-telegraph-status]');
      if (status) {
        status.textContent = selected ? 'تم حفظ بيانات الشحن' : 'اختار المحافظة والمنطقة قبل إتمام الطلب';
        status.classList.toggle('is-ok', selected);
      }
    }
  }

  function setPickerStatus(root, message, ok) {
    if (!root) return;
    var status = root.querySelector('[data-telegraph-status]');
    if (!status) return;
    status.textContent = message;
    status.classList.toggle('is-ok', Boolean(ok));
  }

  function queueSelectionSave(root, selection) {
    var revision = ++saveRevision;
    savePending = true;
    saveFailed = false;
    var snapshot = {
      governorateId: selection.governorateId,
      governorate: selection.governorate,
      areaId: selection.areaId,
      area: selection.area
    };
    var attributes = {
      'Telegraph Governorate ID': snapshot.governorateId,
      'Telegraph Governorate': snapshot.governorate,
      'Telegraph Area ID': snapshot.areaId,
      'Telegraph Area': snapshot.area
    };

    setCheckoutState(root, false);
    setPickerStatus(root, 'جاري حفظ بيانات الشحن...', false);

    var task = saveQueue.catch(function() {}).then(function() {
      return updateCartAttributes(attributes);
    });
    saveQueue = task.catch(function() {});

    task.then(function() {
      if (revision !== saveRevision) return;
      savePending = false;
      setCheckoutState(root, hasSelection(snapshot));
    }, function() {
      if (revision !== saveRevision) return;
      savePending = false;
      saveFailed = true;
      setCheckoutState(root, false);
      setPickerStatus(root, 'تعذر حفظ بيانات الشحن. تأكد من الإنترنت ثم حاول مرة أخرى.', false);
    });
  }

  function buildSelector(target, cart, locations) {
    if (target.querySelector('[data-telegraph-location]')) return;
    var selection = validatedSelection(cart, locations);
    var wrapper = document.createElement('div');
    wrapper.className = 'telegraph-location';
    wrapper.setAttribute('data-telegraph-location', 'true');
    wrapper.innerHTML =
      '<h3 class="telegraph-location__title">بيانات الشحن</h3>' +
      '<p class="telegraph-location__hint">اختار المحافظة والمنطقة المطابقين لشركة الشحن قبل checkout.</p>' +
      '<div class="telegraph-location__grid">' +
        '<div class="telegraph-location__field">' +
          '<label class="telegraph-location__label">المحافظة</label>' +
          '<select class="telegraph-location__select" data-telegraph-governorate></select>' +
        '</div>' +
        '<div class="telegraph-location__field">' +
          '<label class="telegraph-location__label">المنطقة</label>' +
          '<select class="telegraph-location__select" data-telegraph-area disabled></select>' +
        '</div>' +
      '</div>' +
      '<div class="telegraph-location__status" data-telegraph-status></div>';

    target.insertBefore(wrapper, target.firstChild);

    var governorateSelect = wrapper.querySelector('[data-telegraph-governorate]');
    var areaSelect = wrapper.querySelector('[data-telegraph-area]');

    function selectedZone() {
      return locations.find(function(zone) {
        return String(zone.id) === String(governorateSelect.value);
      });
    }

    function renderGovernorates() {
      governorateSelect.innerHTML = '';
      governorateSelect.appendChild(makeOption('', 'اختار المحافظة', !selection.governorateId));
      locations.forEach(function(zone) {
        governorateSelect.appendChild(makeOption(String(zone.id), zone.name, String(zone.id) === String(selection.governorateId)));
      });
    }

    function renderAreas() {
      var zone = selectedZone();
      areaSelect.innerHTML = '';
      areaSelect.disabled = !zone;
      areaSelect.appendChild(makeOption('', zone ? 'اختار المنطقة' : 'اختار المحافظة الأول', !selection.areaId));
      if (!zone) return;
      (zone.subzones || []).forEach(function(area) {
        areaSelect.appendChild(makeOption(String(area.id), area.name, String(area.id) === String(selection.areaId)));
      });
    }

    governorateSelect.addEventListener('change', function() {
      var zone = selectedZone();
      selection.governorateId = zone ? String(zone.id) : '';
      selection.governorate = zone ? zone.name : '';
      selection.areaId = '';
      selection.area = '';
      renderAreas();
      queueSelectionSave(wrapper, selection);
    });

    areaSelect.addEventListener('change', function() {
      var zone = selectedZone();
      var area = zone ? (zone.subzones || []).find(function(entry) {
        return String(entry.id) === String(areaSelect.value);
      }) : null;
      selection.areaId = area ? String(area.id) : '';
      selection.area = area ? area.name : '';
      queueSelectionSave(wrapper, selection);
    });

    renderGovernorates();
    renderAreas();
    setCheckoutState(wrapper, hasSelection(selection));
  }

  // The cart PAGE renders its own zone picker + checkout lock (cart-page.liquid).
  // Stay fully out of its way there so we never double-inject or fight its state.
  function onDedicatedCartPage() { return !!document.querySelector('[data-telegraph-cart]'); }

  function mountSelectors() {
    var runId = ++mountRunId;
    var revisionAtStart = saveRevision;
    if (onDedicatedCartPage() || savePending || saveFailed) return;
    // Resolve the cart first. An empty cart needs neither location data nor a
    // lock, and this order prevents an external fallback from delaying it.
    fetchCart()
      .then(function(cart) {
        if (runId !== mountRunId || savePending || saveFailed || revisionAtStart !== saveRevision) return null;
        if (!cart || !cart.item_count) {
          document.querySelectorAll('[data-telegraph-location]').forEach(function(selector) {
            if (selector.parentNode) selector.parentNode.removeChild(selector);
          });
          setCheckoutState(null, true);
          return null;
        }
        return fetchLocations().then(function(locations) {
          if (runId !== mountRunId || savePending || saveFailed || revisionAtStart !== saveRevision) return null;
          var targets = document.querySelectorAll(
            '.drawer-footer, .cart-page-actions, .cart__footer, .cart-footer, .drawer__footer, .cart__ctas, form[action="/cart"], form[action^="/cart?"]'
          );
          if (targets.length) {
            targets.forEach(function(target) { buildSelector(target, cart, locations); });
          } else {
            // Fallback: drop the picker right above the first real checkout trigger.
            var trig = document.querySelector(CHECKOUT_TRIGGER_SELECTOR + ', ' + EXPRESS_SELECTOR);
            if (trig && trig.parentElement) buildSelector(trig.parentElement, cart, locations);
          }
          setCheckoutState(null, hasSelection(validatedSelection(cart, locations)));
          return null;
        });
      })
      .catch(function() {
        if (runId !== mountRunId || savePending || saveFailed || revisionAtStart !== saveRevision) return;
        // Fail OPEN: the server-side checkout validation is the real guarantee,
        // so bounded cart/location failures must never block all checkout.
        setCheckoutState(null, true);
      });
  }

  function nudgeToPicker() {
    mountSelectors();
    var selector = document.querySelector('[data-telegraph-location]');
    if (selector) {
      selector.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } else if (location.pathname !== '/cart') {
      // Picker not on this page (e.g. product page express button) → send them
      // to the cart where they can choose the zone.
      window.location.href = '/cart';
    }
  }

  // Capture phase so we intercept BEFORE the theme's / Shopify's own handlers —
  // covers checkout links, the cart form button, and express buttons. Only ever
  // blocks when a zone is NOT chosen (never interferes once selected).
  document.addEventListener('click', function(event) {
    // Defensive exemption: this control must reach theme-premium.js so it can
    // add the chosen product and route the buyer to the cart-zone picker.
    if (event.target.closest(PRODUCT_BUY_NOW_SELECTOR)) return;
    if (selectedGlobal || onDedicatedCartPage()) return;
    var trigger = event.target.closest(CHECKOUT_TRIGGER_SELECTOR + ', ' + EXPRESS_SELECTOR);
    if (!trigger) return;
    event.preventDefault();
    event.stopPropagation();
    nudgeToPicker();
  }, true);

  // The cart's checkout button submits a <form> (not a link) — block that path
  // too, but ONLY the checkout submit (never "update cart"/"add").
  document.addEventListener('submit', function(event) {
    if (selectedGlobal || onDedicatedCartPage()) return;
    var form = event.target;
    if (!form || typeof form.matches !== 'function') return;
    if (!form.matches('form[action^="/cart"], form[action="/checkout"], form[action^="/checkout?"]')) return;
    var submitter = event.submitter;
    var goingToCheckout = /\/checkout/.test(form.getAttribute('action') || '') ||
      (submitter && submitter.name === 'checkout');
    if (!goingToCheckout) return; // allow quantity updates etc.
    event.preventDefault();
    nudgeToPicker();
  }, true);

  document.addEventListener('DOMContentLoaded', mountSelectors);
  document.addEventListener('cart:updated', mountSelectors);
  setTimeout(mountSelectors, 800);
  if ('MutationObserver' in window) {
    var observer = new MutationObserver(function() {
      window.clearTimeout(window.__telegraphLocationMountTimer);
      window.__telegraphLocationMountTimer = window.setTimeout(mountSelectors, 120);
    });
    observer.observe(document.body, { childList: true, subtree: true });
  }
})();
</script>
