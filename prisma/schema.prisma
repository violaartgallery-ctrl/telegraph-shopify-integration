generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShipmentRecord {
  id                   Int      @id @default(autoincrement())
  shopifyOrderId       String   @unique
  shopifyOrderNumber   String
  shopifyOrderName     String?
  plannedShipmentCode  String?  @unique
  accurateShipmentId   Int?
  accurateShipmentCode String?
  accurateStatus       String?
  accurateReturnStatus String?
  collectionStatus     String?
  trackingUrl          String?
  collectedAmount      Float?
  pendingCollectionAmount Float?
  returnedValue        Float?
  deliveredAt          DateTime?
  lastSyncedAt         DateTime?
  lastError            String?
  rawOrderJson         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ShipmentSequence {
  name      String   @id
  nextValue Int
  updatedAt DateTime @updatedAt
}

model FailedPayload {
  id          Int      @id @default(autoincrement())
  source      String
  externalId  String?
  reason      String
  payloadJson String
  headersJson String?
  createdAt   DateTime @default(now())
}
