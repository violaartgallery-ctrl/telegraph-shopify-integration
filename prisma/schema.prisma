generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ShipmentRecord {
  id                   Int      @id @default(autoincrement())
  shopifyOrderId       String   @unique
  shopifyOrderNumber   String
  shopifyOrderName     String?
  plannedShipmentCode  String?  @unique
  accurateShipmentId   Int?
  accurateShipmentCode String?
  accurateStatus       String?
  accurateStatusCode   String?
  accurateReturnStatus String?
  accurateReturnStatusCode String?
  accurateIsTerminal   Boolean?
  collectionStatus     String?
  trackingUrl          String?
  collectedAmount      Float?
  pendingCollectionAmount Float?
  returnedValue        Float?
  deliveryFees         Float?
  returnFees           Float?
  returningDueFees     Float?
  customerDue          Float?
  deliveredAt          DateTime?
  lastSyncedAt         DateTime?
  lastError            String?
  odooSaleOrderId      Int?
  odooSaleOrderName    String?
  odooInvoiceId        Int?
  odooInvoiceName      String?
  odooPaymentId        Int?
  odooSalePaymentId    Int?
  odooReturnBillId     Int?
  odooReturnPaymentId  Int?
  odooSyncStatus       String?
  odooLastError        String?
  odooSyncedAt         DateTime?
  rawOrderJson         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ShipmentSequence {
  name      String   @id
  nextValue Int
  updatedAt DateTime @updatedAt
}

model FailedPayload {
  id          Int      @id @default(autoincrement())
  source      String
  externalId  String?
  reason      String
  payloadJson String
  headersJson String?
  createdAt   DateTime @default(now())
}
